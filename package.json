{
  "name": "swarmapi",
  "private": true,
  "version": "0.0.0",
  "description": "x402 monetization gateway, SDK, dashboard, and marketplace.",
  "workspaces": [
    "packages/*",
    "apps/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build -w @swarmapi/sdk -w @swarmapi/db -w @swarmapi/company-intel -w @swarmapi/gateway --if-present",
    "build:libs": "npm run build -w @swarmapi/sdk -w @swarmapi/mcp -w @swarmapi/setup --if-present",
    "start": "node packages/gateway/dist/index.js",
    "dev": "npm run dev --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "prepare": "npm run build -w @swarmapi/sdk --if-present"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
