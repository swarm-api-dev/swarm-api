{
  "name": "@agentpay/db",
  "version": "0.0.0",
  "private": true,
  "description": "Shared SQLite + Drizzle schema for payment events.",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
