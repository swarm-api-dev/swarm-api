{
  "name": "@swarm-api/setup",
  "version": "0.2.2",
  "license": "MIT",
  "description": "One-shot CLI for SwarmApi: generate or import a Base wallet (hex or BIP-39), fund via Coinbase Onramp, and write an MCP config block for Claude Desktop / Cursor / Cline / Zed.",
  "keywords": [
    "swarmapi",
    "x402",
    "mcp",
    "model-context-protocol",
    "base",
    "usdc",
    "ai-agents",
    "wallet"
  ],
  "homepage": "https://swarm-api.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/swarm-api-dev/swarm-api.git",
    "directory": "packages/setup"
  },
  "bugs": {
    "url": "https://github.com/swarm-api-dev/swarm-api/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "swarmapi-setup": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../tools/ensure-shebang.mjs dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "open": "^10.1.0",
    "viem": "^2.39.3"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2"
  }
}
