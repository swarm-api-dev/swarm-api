{
  "name": "@swarmapi/setup",
  "version": "0.1.0",
  "license": "MIT",
  "description": "Interactive CLI: generate a Base wallet, fund it via Coinbase Onramp, and write a Claude Desktop MCP config block.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "swarmapi-setup": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../tools/ensure-shebang.mjs dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "open": "^10.1.0",
    "viem": "^2.39.3"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2"
  }
}
