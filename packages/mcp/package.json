{
  "name": "@swarmapi/mcp",
  "version": "0.0.0",
  "private": true,
  "description": "MCP server exposing SwarmApi company-intelligence endpoints as tools for AI agents (Claude Desktop, Cursor, etc.).",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "swarmapi-mcp": "src/index.ts"
  },
