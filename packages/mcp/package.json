{
  "name": "@swarm-api/mcp",
  "version": "0.1.2",
  "license": "MIT",
  "description": "MCP server for SwarmApi: 9 pay-per-call tools for SEC filings, company news, insider transactions, jobs, web search, GitHub repos, and npm/PyPI/cargo package security. Payments settled per request in USDC on Base via x402.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "swarmapi-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "x402",
    "usdc",
    "base",
    "sec",
    "edgar",
    "company-intelligence",
    "agent-tools",
    "claude-desktop",
    "cursor"
  ],
  "homepage": "https://swarm-api.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swarm-api-dev/swarm-api.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/swarm-api-dev/swarm-api/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../tools/ensure-shebang.mjs dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@swarmapi/sdk": "^0.1.0",
    "@modelcontextprotocol/sdk": "^1.18.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2"
  }
}
