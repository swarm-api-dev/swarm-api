{
  "name": "@swarmapi/mcp",
  "version": "0.1.0",
  "license": "MIT",
  "description": "MCP server exposing SwarmApi company + code intelligence endpoints as tools for AI agents (Claude Desktop, Cursor, etc.).",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "swarmapi-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../tools/ensure-shebang.mjs dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@swarmapi/sdk": "^0.1.0",
    "@modelcontextprotocol/sdk": "^1.18.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2"
  }
}
