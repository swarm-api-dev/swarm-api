{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPatterns": [
      "packages/gateway/**",
      "packages/db/**",
      "packages/company-intel/**",
      "Dockerfile",
      "package.json",
      "package-lock.json",
      "tsconfig.base.json"
    ]
  },
  "deploy": {
    "startCommand": "node_modules/.bin/tsx packages/gateway/src/index.ts",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
