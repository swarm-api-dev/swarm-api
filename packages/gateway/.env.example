PORT=3000

# Receiving wallet (Base Sepolia). Any 0x address is valid for testing 402 generation.
# Use your own address before exercising the SDK end-to-end so testnet USDC actually lands somewhere you control.
PAY_TO_ADDRESS=0x0000000000000000000000000000000000000001

# x402 facilitator. The foundation/Coinbase hosted Sepolia facilitator is the default; override if self-hosting.
FACILITATOR_URL=https://x402.org/facilitator

# SQLite file for payment events. Defaults to ./agentpay.sqlite in the gateway's CWD.
# DB_PATH=../../agentpay.sqlite
