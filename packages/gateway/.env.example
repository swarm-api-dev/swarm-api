PORT=3000

# Receiving wallet. Same EOA works on Base mainnet and Base Sepolia (different USDC balances per chain).
PAY_TO_ADDRESS=0x0000000000000000000000000000000000000001

# Which Base profile to run against. Defaults to base-mainnet.
#   base-mainnet → eip155:8453, mainnet USDC, PayAI facilitator (real money).
#   base-sepolia → eip155:84532, testnet USDC, x402.org/facilitator (testnet only).
NETWORK_PROFILE=base-mainnet

# Override the facilitator URL. Leave commented to use the profile default:
#   base-mainnet  → https://api.cdp.coinbase.com/platform/v2/x402  (Coinbase CDP, recommended,
#                                                                    requires CDP_API_KEY_NAME/SECRET below;
#                                                                    falls back to PayAI when those are unset)
#   base-sepolia  → https://x402.org/facilitator                    (foundation testnet, no auth)
# FACILITATOR_URL=

# Coinbase Developer Platform credentials. Required to use the CDP facilitator on mainnet.
# Get them at https://portal.cdp.coinbase.com/access/api → "API keys".
# CDP_API_KEY_NAME is typically formatted like 'organizations/<uuid>/apiKeys/<uuid>'.
# CDP_API_KEY_SECRET is the multi-line PEM private key — paste the full block including
# BEGIN/END markers, escaping newlines as \n if dotenv requires it.
# When both are set with the CDP facilitator URL, the gateway signs every facilitator
# request with a fresh ES256/EdDSA JWT scoped to the request URI.
# CDP_API_KEY_NAME=
# CDP_API_KEY_SECRET=

# SQLite path. Defaults to <repo-root>/swarmapi.sqlite.
# DB_PATH=

# Brave Search API key (required for /v1/web/search). Get one from
# https://api.search.brave.com — free tier covers 2000 queries/month.
# Without this set, /v1/web/search returns 503 with a clear error message.
# BRAVE_API_KEY=

# GitHub personal access token (recommended for /v1/github/repo). Optional but
# without it the gateway falls back to unauthenticated requests at 60 req/hr
# shared across all callers — fine for low traffic, terrible at scale.
# Generate one at https://github.com/settings/tokens (no scopes needed for
# public repos).
# GITHUB_TOKEN=
