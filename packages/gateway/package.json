{
  "name": "@swarmapi/gateway",
  "version": "0.0.0",
  "private": true,
  "description": "x402 payment gateway: Express server that 402-gates API endpoints via @x402/express.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@swarmapi/company-intel": "*",
    "@swarmapi/db": "*",
    "@x402/core": "^2.11.0",
    "@x402/evm": "^2.11.0",
    "@x402/express": "^2.11.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2"
  }
}
